{
  "name": "crypto-manual-alert-frontend",
  "version": "2.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run tests/unit",
    "build": "next build",
    "test:e2e": "playwright test",
    "test:e2e:real-inbox": "REAL_PRODUCT_E2E=1 PLAYWRIGHT_EXTERNAL_SERVER=1 PLAYWRIGHT_FRONTEND_BASE_URL=${PLAYWRIGHT_FRONTEND_BASE_URL:-http://127.0.0.1:3001} playwright test tests/e2e-v2/real-inbox-flow.spec.ts",
    "test:e2e:real-multi-interrupt": "REAL_MULTI_INTERRUPT_E2E=1 PLAYWRIGHT_EXTERNAL_SERVER=1 PLAYWRIGHT_FRONTEND_BASE_URL=${PLAYWRIGHT_FRONTEND_BASE_URL:-http://127.0.0.1:3001} playwright test tests/e2e-v2/real-multi-interrupt-flow.spec.ts",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@langchain/core": "1.2.2",
    "@langchain/langgraph-sdk": "1.9.25",
    "@langchain/protocol": "0.0.18",
    "@langchain/react": "1.0.26",
    "lucide-react": "1.24.0",
    "next": "16.2.10",
    "next-auth": "4.24.14",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "rehype-sanitize": "6.0.0",
    "zod": "4.4.3"
  },
  "overrides": {
    "postcss": "8.5.10",
    "uuid": "11.1.1"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "axe-core": "4.12.1",
    "eslint": "9.39.2",
    "eslint-config-next": "16.2.10",
    "typescript": "5.9.3",
    "vitest": "4.1.10"
  }
}
