# Non-secret defaults for the local real Deep Research proof profile.
APP_ENVIRONMENT=development
SEARCH_PROVIDER=builtin_web_search
DEEP_RESEARCH_HARNESS_MODE=deepagents
REAL_DEEP_RESEARCH_AGENT_PORT=18123
REAL_DEEP_RESEARCH_WORKER_PORT=19090
REAL_DEEP_RESEARCH_FRONTEND_PORT=13001
REAL_DEEP_RESEARCH_DATABASE_PREFIX=crypto_alert_v2_e2e
REAL_DEEP_RESEARCH_STARTUP_TIMEOUT_SECONDS=120
REAL_DEEP_RESEARCH_WORKSPACE_TIMEOUT_SECONDS=60
PLAYWRIGHT_ALLOW_BROWSER_ROUTES=0
DEVELOPMENT_BOOTSTRAP_ENABLED=true
DEVELOPMENT_BOOTSTRAP_PROFILE=local-proof
DEVELOPMENT_BOOTSTRAP_SUBJECT=real-deep-research-user
DEVELOPMENT_BOOTSTRAP_IDENTITY_ISSUER=crypto-alert-v2-real-deep-research
DEVELOPMENT_BOOTSTRAP_TENANT_ID=real-deep-research-tenant
DEVELOPMENT_BOOTSTRAP_WORKSPACE_ID=real-deep-research-workspace
DEVELOPMENT_BOOTSTRAP_ROLES=["member"]
DEVELOPMENT_BOOTSTRAP_PERMISSIONS=["analysis:read","analysis:write"]
