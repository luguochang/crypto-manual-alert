{
  "meta": {
    "name": "Signal Desk V2 UI Tokens",
    "version": "1.0.0",
    "theme": "deep-black-financial-terminal",
    "note": "Manual-only, evidence-first crypto intelligence workspace."
  },
  "color": {
    "background": {
      "canvas": "#020609",
      "canvasRaised": "#050B10",
      "sidebar": "#03090E",
      "surface": "#071119",
      "surfaceRaised": "#0A151E",
      "surfaceHover": "#0D1A24",
      "overlay": "rgba(2, 6, 9, 0.78)"
    },
    "border": {
      "subtle": "#13212B",
      "default": "#1B2B36",
      "strong": "#2B3F4C",
      "focus": "#17D98A"
    },
    "text": {
      "primary": "#F3F6F8",
      "secondary": "#A2AFB9",
      "tertiary": "#6F7E89",
      "inverse": "#03110B",
      "disabled": "#46535C"
    },
    "brand": {
      "primary": "#00C979",
      "primaryHover": "#18D98A",
      "primaryPressed": "#00A965",
      "primaryMuted": "#062A1D",
      "cyan": "#14B8D4",
      "blue": "#3B82F6"
    },
    "semantic": {
      "success": "#00D084",
      "warning": "#F2A51A",
      "danger": "#F04452",
      "info": "#3B82F6",
      "blocked": "#A855F7"
    },
    "market": {
      "up": "#00C979",
      "down": "#F04452",
      "neutral": "#8B98A3",
      "candleUp": "#00C979",
      "candleDown": "#F04452",
      "volumeUp": "rgba(0, 201, 121, 0.42)",
      "volumeDown": "rgba(240, 68, 82, 0.42)"
    }
  },
  "radius": {
    "xs": "4px",
    "sm": "6px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "pill": "999px"
  },
  "shadow": {
    "panel": "0 1px 0 rgba(255,255,255,.02), 0 16px 40px rgba(0,0,0,.28)",
    "floating": "0 24px 70px rgba(0,0,0,.52)",
    "focus": "0 0 0 3px rgba(0,201,121,.18)"
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "20px",
    "6": "24px",
    "8": "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px"
  },
  "typography": {
    "fontSans": "Inter, \"PingFang SC\", \"Microsoft YaHei\", system-ui, sans-serif",
    "fontMono": "\"JetBrains Mono\", \"SFMono-Regular\", Consolas, monospace",
    "display": {
      "fontSize": "64px",
      "lineHeight": "1.08",
      "fontWeight": 650,
      "letterSpacing": "-0.035em"
    },
    "h1": {
      "fontSize": "32px",
      "lineHeight": "1.2",
      "fontWeight": 620
    },
    "h2": {
      "fontSize": "22px",
      "lineHeight": "1.3",
      "fontWeight": 600
    },
    "body": {
      "fontSize": "14px",
      "lineHeight": "1.6",
      "fontWeight": 400
    },
    "caption": {
      "fontSize": "12px",
      "lineHeight": "1.45",
      "fontWeight": 400
    },
    "numeric": {
      "fontVariantNumeric": "tabular-nums slashed-zero"
    }
  },
  "motion": {
    "fast": "120ms",
    "normal": "180ms",
    "slow": "320ms",
    "easeStandard": "cubic-bezier(.2,.8,.2,1)",
    "easeEmphasized": "cubic-bezier(.2,0,0,1)"
  }
}