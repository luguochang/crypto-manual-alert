# V2 local development profile. Copy values into backend/.env or inject them
# through the process environment. Never commit real credentials.
APP_ENVIRONMENT=development

MODEL_NAME=gpt-5.5
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=

# builtin_web_search is the production default. ddgs_metasearch is an explicit
# local zero-mock automatic metasearch fallback when the configured model endpoint
# does not expose the Responses Web Search tool. Tavily requires TAVILY_API_KEY.
SEARCH_PROVIDER=builtin_web_search
TAVILY_API_KEY=

# Leave blank on unrestricted networks. For a host-run stack, a local proxy can
# use http://127.0.0.1:7890. Containers need a host-reachable address such as
# http://host.docker.internal:7890 on Docker Desktop.
MARKET_DATA_HTTP_PROXY=
SEARCH_HTTP_PROXY=

PRODUCT_DATABASE_URL=postgresql+asyncpg://crypto_alert:crypto_alert_local@127.0.0.1:55435/crypto_alert_v2
AGENT_SERVER_URL=http://127.0.0.1:8123
AGENT_ASSISTANT_ID=crypto_analysis
# The durable Docker Agent Server requires either a LangGraph Cloud license
# key or a LangSmith key with the required deployment access. Keep this empty
# in a committed template and inject the real value through a secret manager
# or the process environment.
LANGGRAPH_CLOUD_LICENSE_KEY=
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=crypto-alert-v2
WORKER_READINESS_URL=
AGENT_READINESS_URL=
AGENT_READINESS_HOST=127.0.0.1
AGENT_READINESS_PORT=9091
AGENT_READINESS_INTERVAL_SECONDS=5
AGENT_READINESS_PROBE_TIMEOUT_SECONDS=10
AGENT_READINESS_FAILURE_THRESHOLD=3
AGENT_READINESS_STALE_AFTER_SECONDS=30
WORKER_READINESS_FAILURE_THRESHOLD=3
WORKER_READINESS_STALE_AFTER_SECONDS=30

# Compose encrypts owner-scoped notification credentials at rest. This is a
# deployment secret, not a user device key. Generate a new value per
# environment and rotate it with NOTIFICATION_CREDENTIAL_DECRYPT_KEYS.
NOTIFICATION_CREDENTIAL_KEY=
NOTIFICATION_CREDENTIAL_KEY_VERSION=v1
NOTIFICATION_CREDENTIAL_DECRYPT_KEYS=

DEVELOPMENT_BOOTSTRAP_ENABLED=true
DEVELOPMENT_BOOTSTRAP_PROFILE=local-proof
DEVELOPMENT_BOOTSTRAP_SUBJECT=dev-user
DEVELOPMENT_BOOTSTRAP_IDENTITY_ISSUER=crypto-alert-v2-local-proof
DEVELOPMENT_BOOTSTRAP_CONTEXT_ID=99999999-9999-4999-8999-999999999999
DEVELOPMENT_BOOTSTRAP_TENANT_ID=dev-tenant
DEVELOPMENT_BOOTSTRAP_WORKSPACE_ID=dev-workspace
DEVELOPMENT_BOOTSTRAP_ROLES=["member"]
DEVELOPMENT_BOOTSTRAP_PERMISSIONS=["analysis:read","analysis:write"]

# Optional observability. Enabling either transport requires its corresponding
# credentials; disabled transports remain explicit no-ops.
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
