# Safe defaults: no automatic trading and no manual alert until explicitly enabled.
APP_MODE=SHADOW
AUTO_ORDER_ENABLED=false
MARKET_DATA_PROVIDER=fixture
# OKX public HTTP is isolated from ambient proxy variables by default.
# In a restricted production network, either enable trusted HTTP(S)_PROXY /
# NO_PROXY inheritance or set a dedicated proxy URL for the OKX client.
MARKET_DATA_HTTP_TRUST_ENV=false
MARKET_DATA_HTTP_PROXY=
DECISION_ENGINE=fixture
NOTIFICATION_ENABLED=false
# Raw payload and real external judge routes are engineering diagnostics.
# Keep disabled in shared/prod deployments; local stack smoke enables this
# explicitly so Playwright can verify redaction behavior.
DIAGNOSTIC_ROUTES_ENABLED=false
# Scheduler runs only via the CLI `scheduler` subcommand, not inside the API service.
SCHEDULER_ENABLED=false
SCHEDULER_INTERVAL_SECONDS=1800
SCHEDULER_JOB_TIMEOUT_SECONDS=1800

# Optional container build base images. Override these when the target server
# uses a private registry or cannot reach Docker Hub reliably.
PYTHON_BASE_IMAGE=python:3.12-slim
NODE_BASE_IMAGE=node:22-alpine

# facts_gate event-fact control. disabled (default) blocks opening/trigger/flip
# actions. Set no_active_event only when the operator has confirmed no scheduled
# macro event affects the symbol's horizon window. Prod-actionable proof also
# requires the assertion metadata below; local actionable staging may omit it
# because it is only a wiring proof. See docs/deployment.md.
MACRO_EVENT_PROVIDER=disabled
MACRO_EVENT_OPERATOR_REF=
MACRO_EVENT_CONFIRMED_AT=
MACRO_EVENT_SOURCE_REF=
MACRO_EVENT_ASSERTION_HORIZON=
MACRO_EVENT_VALID_UNTIL=

# Required only when NOTIFICATION_ENABLED=true
BARK_DEVICE_KEY=

# DECISION_ENGINE=command is intentionally disabled in manual-alert v1.
# Keep DECISION_COMMAND empty; use openai_compatible for real model analysis.
DECISION_COMMAND=

# Optional if DECISION_ENGINE=openai_compatible.
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_API_KEY=
DECISION_TIMEOUT_SECONDS=1200

# Optional research fallback. These are per-request timeouts, not a 60s whole-job limit.
RESEARCH_ENABLED=false
RESEARCH_PLANNER=static
RESEARCH_LEADER_MODE=static
RESEARCH_SEARCH_PROVIDER=disabled
RESEARCH_MAX_QUERIES=6
RESEARCH_MAX_WORKERS=4
RESEARCH_REQUEST_TIMEOUT_SECONDS=300

# v1 uses OKX public market data only. Do not set OKX private account,
# trade, withdraw, secret, or passphrase environment variables.
