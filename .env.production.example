# Production-intent hosted workbench template.
# Copy to .env, fill real values, then run the strict smokes in docs/deployment.md.
# This template still keeps manual-only safety: no automatic orders, no trade keys.

APP_MODE=MANUAL_ALERT
AUTO_ORDER_ENABLED=false
CONFIG_PATHS=config/default.yaml:config/prod.yaml:config/staging.yaml
DIAGNOSTIC_ROUTES_ENABLED=false
SCHEDULER_ENABLED=false

API_PORT=8010
FRONTEND_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8010
API_INTERNAL_BASE_URL=http://api:8010

PYTHON_BASE_IMAGE=python:3.12-slim
NODE_BASE_IMAGE=node:22-alpine

MARKET_DATA_PROVIDER=okx_public
# Keep false for direct egress. Set true only when the deployment intentionally
# provides HTTP_PROXY/HTTPS_PROXY/NO_PROXY to the API/scheduler process.
MARKET_DATA_HTTP_TRUST_ENV=false
# Optional dedicated http/https proxy for OKX public requests. The value is
# redacted from the safe config API because proxy URLs can contain credentials.
MARKET_DATA_HTTP_PROXY=
DECISION_ENGINE=openai_compatible
OPENAI_BASE_URL=
OPENAI_MODEL=
OPENAI_API_KEY=
DECISION_TIMEOUT_SECONDS=1200
CANDIDATE_SIDECAR_MODE=disabled
WORKFLOW_EXECUTION_MODE=legacy_baseline

RESEARCH_ENABLED=true
RESEARCH_PLANNER=llm
RESEARCH_LEADER_MODE=llm
RESEARCH_SEARCH_PROVIDER=responses_web_search
RESEARCH_MAX_QUERIES=6
RESEARCH_MAX_WORKERS=4
RESEARCH_REQUEST_TIMEOUT_SECONDS=300

NOTIFICATION_ENABLED=true
BARK_DEVICE_KEY=

MACRO_EVENT_PROVIDER=no_active_event
MACRO_EVENT_OPERATOR_REF=
MACRO_EVENT_CONFIRMED_AT=
MACRO_EVENT_SOURCE_REF=
MACRO_EVENT_ASSERTION_HORIZON=
MACRO_EVENT_VALID_UNTIL=
